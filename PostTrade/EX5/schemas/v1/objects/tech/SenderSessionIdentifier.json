{
  "$schema" : "http://json-schema.org/draft-07/schema#",
  "$id" : "urn:a5x:ex5:schema:v1:tech:SenderSessionIdentifier",
  "$metadata" : {
    "domain" : "tech",
    "schemaId" : "urn:a5x:ex5:schema:v1:tech:SenderSessionIdentifier"
  },
  "title" : "SenderSessionIdentifier",
  "type" : "string",
  "examples" : [ "GTWA5XD001", "P000999ALC001" ],
  "oneOf" : [
    {
      "description" : "Session identifier. Format 1: {ENVIRONMENT FIRST LETTER}{PARTICIPANT CODE}{MESSAGES CATEGORY}{SEQUENCE}",
      "pattern" : "^[PCUDH][0-9]{6}[A-Z]{3}[0-9]{3}$"
    },
    {
      "description" : "Session identifier. Format 1: {GATEWAY}{A5X}{ENVIRONMENT FIRST LETTER}{SEQUENCE}",
      "pattern" : "^GTWA5X[PCUDH]{1,3}[0-9]{0,3}$"
    }
  ]
}
